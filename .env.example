# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# --- Livoltek cloud portal ---
LIVOLTEK_PORTAL_URL=https://evs.livoltek-portal.com/#/
LIVOLTEK_USERNAME=
LIVOLTEK_PASSWORD=
# Persistent cookie/session store — keep cycles short across runs
LIVOLTEK_STORAGE_STATE_PATH=browser-data/storage_state.json
# Per-action timeout in seconds (login, navigation, waits)
LIVOLTEK_BROWSER_TIMEOUT_S=30
# Headless=true for unattended cron runs. Headed (false) for debugging.
LIVOLTEK_HEADLESS=false

# --- Elering Nord Pool API ---
ELERING_BASE_URL=https://dashboard.elering.ee/api
ELERING_REGION=lv

# --- Trading strategy ---
# Battery nominal capacity in kWh — user has 2× Livoltek LFP modules = 10.24 kWh nominal
BATTERY_CAPACITY_KWH=10.24
# Round-trip efficiency 0–1 (LFP + inverter typical 0.88–0.92)
ROUND_TRIP_EFFICIENCY=0.90
# Battery cost in EUR (used to derive per-cycle wear cost)
BATTERY_PRICE_EUR=3000
# Battery rated cycles to 80% capacity (LFP nominal ~6000)
BATTERY_CYCLE_LIFE=6000
# Maximum charge cycles per day (Livoltek portal allows up to 6 schedule slots).
# Battery wear cost per cycle naturally caps the picked number to profitable ones.
MAX_CYCLES_PER_DAY=6
# Hours per cycle (consecutive hours to charge or discharge)
HOURS_PER_CYCLE=2
# Required net profit per cycle in EUR, after deducting wear cost.
# Default 0.25 — covers the ~0.18 EUR forecast error band on a 9.2 kWh cycle
# (Open-Meteo MAE ≈ 0.02 EUR/kWh on spread) and leaves a small risk margin.
# Set to 0 to allow any wear-positive cycle; raise it to be more conservative.
MIN_NET_PROFIT_PER_CYCLE_EUR=0.25

# --- PV system + Open-Meteo solar forecast ---
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
# Site coordinates (Pleskodāle, Rīga ~56.918 N, 24.043 E)
PV_LAT=56.918
PV_LON=24.043
# Empirical conversion factor calibrated from production history:
# expected_kwh = shortwave_radiation_sum_MJ_per_m² × pv_kwh_per_mj_m2
# 2.98 reflects the user's 10 kWp + south/SW orientation; recalibrate if the system changes.
PV_KWH_PER_MJ_M2=2.98
# Default daily total household load in kWh (Livoltek `Load Consumption` mean).
# Used to decide if PV will cover the day; tune seasonally.
EXPECTED_DAILY_LOAD_KWH=22.0
OPEN_METEO_TIMEOUT_S=15.0

# --- Notifications (ntfy) ---
NTFY_BASE_URL=https://ntfy.sh
# Required: pick a long, unguessable topic — anyone with the topic name can read messages on ntfy.sh
NTFY_TOPIC=
# Optional: Bearer token if you self-host ntfy with auth, or use ntfy.sh paid topics
NTFY_TOKEN=
NTFY_TIMEOUT_S=10.0

# --- Runtime ---
# Set to `true` to compute and notify but skip portal writes
DRY_RUN=true
LOG_LEVEL=INFO
